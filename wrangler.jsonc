{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "fixbee-calc",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"directory": ".svelte-kit/cloudflare",
		"binding": "ASSETS"
	},
	"compatibility_date": "2026-03-04",
	"compatibility_flags": ["nodejs_als", "nodejs_compat"],
	"observability": {
		"enabled": true
	},
	"keep_vars": true
}
